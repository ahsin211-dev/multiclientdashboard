generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum Marketplace {
  US
  CA
  UK
  DE
  FR
  IT
  ES
}

enum ConnectionType {
  AMAZON_ADS
  SP_API
}

enum ConnectionStatus {
  DISCONNECTED
  PENDING
  CONNECTED
  ERROR
}

enum SyncStatus {
  IDLE
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum MatchType {
  EXACT
  PHRASE
  BROAD
  AUTO
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ChatRole {
  SYSTEM
  USER
  ASSISTANT
}

enum RecordStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model User {
  id           String            @id @default(cuid())
  name         String
  email        String            @unique
  passwordHash String?
  image        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  memberships  WorkspaceMember[]
  chatSessions ChatSession[]
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  slug      String            @unique
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  members   WorkspaceMember[]
  clients   Client[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

model Client {
  id             String             @id @default(cuid())
  workspaceId    String
  brandName      String
  marketplace    Marketplace
  syncStatus     SyncStatus         @default(IDLE)
  lastSyncAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  connections    AmazonConnection[]
  adAccounts     AdAccount[]
  campaigns      Campaign[]
  adGroups       AdGroup[]
  keywords       Keyword[]
  searchTerms    SearchTerm[]
  products       Product[]
  salesMetrics   SalesMetric[]
  adMetrics      AdMetric[]
  sqpMetrics     SQPMetric[]
  auditReports   AuditReport[]
  marketingPlans MarketingPlan[]
  chatSessions   ChatSession[]
  syncJobs       DataSyncJob[]

  @@index([workspaceId, brandName])
}

model AmazonConnection {
  id                   String           @id @default(cuid())
  clientId             String
  type                 ConnectionType
  status               ConnectionStatus @default(PENDING)
  accountName          String?
  marketplace          Marketplace
  accessTokenEncrypted String?
  refreshTokenEncrypted String?
  tokenExpiresAt       DateTime?
  metadata             Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  client               Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  adAccounts           AdAccount[]

  @@index([clientId, type])
}

model AdAccount {
  id                 String            @id @default(cuid())
  clientId           String
  amazonConnectionId String?
  accountId          String            @unique
  profileId          String?
  accountName        String
  currency           String            @default("USD")
  timezone           String            @default("UTC")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  client             Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amazonConnection   AmazonConnection? @relation(fields: [amazonConnectionId], references: [id], onDelete: SetNull)
  campaigns          Campaign[]

  @@index([clientId])
}

model Campaign {
  id              String         @id @default(cuid())
  clientId        String
  adAccountId     String
  externalId      String         @unique
  name            String
  status          CampaignStatus @default(ACTIVE)
  channel         String         @default("sponsoredProducts")
  budget          Decimal        @db.Decimal(12, 2)
  biddingStrategy String?
  startDate       DateTime?
  endDate         DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  adAccount       AdAccount      @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  adGroups        AdGroup[]
  adMetrics       AdMetric[]

  @@index([clientId, status])
}

model AdGroup {
  id         String     @id @default(cuid())
  clientId   String
  campaignId String
  externalId String     @unique
  name       String
  defaultBid Decimal?   @db.Decimal(12, 2)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign   Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywords   Keyword[]
  adMetrics  AdMetric[]

  @@index([clientId, campaignId])
}

model Keyword {
  id         String      @id @default(cuid())
  clientId   String
  adGroupId  String
  text       String
  matchType  MatchType
  state      String      @default("enabled")
  bid        Decimal?    @db.Decimal(12, 2)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  adGroup    AdGroup     @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
  searchTerms SearchTerm[]
  adMetrics  AdMetric[]

  @@index([clientId, matchType])
}

model SearchTerm {
  id         String     @id @default(cuid())
  clientId   String
  keywordId  String?
  term       String
  matchType  MatchType?
  spend      Decimal    @default(0) @db.Decimal(12, 2)
  sales      Decimal    @default(0) @db.Decimal(12, 2)
  clicks     Int        @default(0)
  orders     Int        @default(0)
  ctr        Decimal    @default(0) @db.Decimal(8, 4)
  cvr        Decimal    @default(0) @db.Decimal(8, 4)
  acos       Decimal    @default(0) @db.Decimal(8, 4)
  roas       Decimal    @default(0) @db.Decimal(12, 4)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  keyword    Keyword?   @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  adMetrics  AdMetric[]

  @@index([clientId, term])
}

model Product {
  id           String        @id @default(cuid())
  clientId     String
  asin         String
  sku          String?
  title        String
  price        Decimal       @db.Decimal(12, 2)
  category     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salesMetrics SalesMetric[]
  sqpMetrics   SQPMetric[]

  @@unique([clientId, asin])
  @@index([clientId, title])
}

model SalesMetric {
  id             String    @id @default(cuid())
  clientId       String
  productId      String
  date           DateTime
  sessions       Int       @default(0)
  unitsOrdered   Int       @default(0)
  totalOrders    Int       @default(0)
  revenue        Decimal   @db.Decimal(12, 2)
  organicSales   Decimal   @default(0) @db.Decimal(12, 2)
  tacos          Decimal   @default(0) @db.Decimal(8, 4)
  conversionRate Decimal   @default(0) @db.Decimal(8, 4)
  createdAt      DateTime  @default(now())
  client         Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product        Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, date])
  @@index([clientId, date])
}

model AdMetric {
  id           String      @id @default(cuid())
  clientId     String
  campaignId   String?
  adGroupId    String?
  keywordId    String?
  searchTermId String?
  date         DateTime
  spend        Decimal     @db.Decimal(12, 2)
  sales        Decimal     @db.Decimal(12, 2)
  impressions  Int         @default(0)
  clicks       Int         @default(0)
  orders       Int         @default(0)
  ctr          Decimal     @default(0) @db.Decimal(8, 4)
  cpc          Decimal     @default(0) @db.Decimal(12, 4)
  cvr          Decimal     @default(0) @db.Decimal(8, 4)
  acos         Decimal     @default(0) @db.Decimal(8, 4)
  roas         Decimal     @default(0) @db.Decimal(12, 4)
  createdAt    DateTime    @default(now())
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign     Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  adGroup      AdGroup?    @relation(fields: [adGroupId], references: [id], onDelete: SetNull)
  keyword      Keyword?    @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  searchTerm   SearchTerm? @relation(fields: [searchTermId], references: [id], onDelete: SetNull)

  @@index([clientId, date])
  @@index([campaignId, date])
}

model SQPMetric {
  id              String    @id @default(cuid())
  clientId        String
  productId       String?
  date            DateTime
  query           String
  impressionShare Decimal   @default(0) @db.Decimal(8, 4)
  clickShare      Decimal   @default(0) @db.Decimal(8, 4)
  cartAddShare    Decimal   @default(0) @db.Decimal(8, 4)
  purchaseShare   Decimal   @default(0) @db.Decimal(8, 4)
  spend           Decimal   @default(0) @db.Decimal(12, 2)
  clicks          Int       @default(0)
  orders          Int       @default(0)
  sales           Decimal   @default(0) @db.Decimal(12, 2)
  acos            Decimal   @default(0) @db.Decimal(8, 4)
  roas            Decimal   @default(0) @db.Decimal(12, 4)
  recommendedAction String?
  createdAt       DateTime  @default(now())
  client          Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product         Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([clientId, date])
  @@index([clientId, query])
}

model AuditReport {
  id              String       @id @default(cuid())
  clientId        String
  title           String
  summary         String
  findings        Json
  recommendations Json
  status          RecordStatus @default(DRAFT)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  client          Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

model MarketingPlan {
  id         String       @id @default(cuid())
  clientId   String
  title      String
  plan       Json
  roadmap    Json
  status     RecordStatus @default(DRAFT)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, createdAt])
}

model ChatSession {
  id         String        @id @default(cuid())
  clientId   String
  userId     String
  title      String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   ChatMessage[]

  @@index([clientId, userId])
}

model ChatMessage {
  id         String    @id @default(cuid())
  sessionId  String
  role       ChatRole
  content    String
  metadata   Json?
  createdAt  DateTime  @default(now())
  session    ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

model DataSyncJob {
  id           String    @id @default(cuid())
  clientId     String
  type         String
  status       JobStatus @default(PENDING)
  attempts     Int       @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  errorMessage String?
  log          Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  client       Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
  @@index([createdAt])
}
