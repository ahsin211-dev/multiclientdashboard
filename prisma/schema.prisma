generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum WorkspaceRole {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}

enum Marketplace {
  US
  CA
  MX
  UK
  DE
  FR
  IT
  ES
  JP
  AU
}

enum ConnectionType {
  ADS
  SP_API
  BRAND_ANALYTICS
}

enum ConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
  TOKEN_EXPIRED
}

enum SyncStatus {
  NEVER_SYNCED
  SYNCING
  SYNCED
  FAILED
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM
}

enum AuditStatus {
  DRAFT
  RUNNING
  COMPLETED
  FAILED
}

model User {
  id             String            @id @default(cuid())
  email          String            @unique
  name           String
  imageUrl       String?
  passwordHash   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  memberships    WorkspaceMember[]
  chatMessages   ChatMessage[]
}

model Workspace {
  id          String            @id @default(cuid())
  name        String
  slug        String            @unique
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  members     WorkspaceMember[]
  clients     Client[]
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  role        WorkspaceRole
  userId      String
  workspaceId String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
}

model Client {
  id                 String             @id @default(cuid())
  brandName          String
  marketplace        Marketplace
  workspaceId        String
  syncStatus         SyncStatus         @default(NEVER_SYNCED)
  lastSyncAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  amazonConnections  AmazonConnection[]
  adAccounts         AdAccount[]
  campaigns          Campaign[]
  searchTerms        SearchTerm[]
  products           Product[]
  salesMetrics       SalesMetric[]
  adMetrics          AdMetric[]
  sqpMetrics         SQPMetric[]
  auditReports       AuditReport[]
  marketingPlans     MarketingPlan[]
  chatSessions       ChatSession[]
  dataSyncJobs       DataSyncJob[]

  @@index([workspaceId, brandName])
}

model AmazonConnection {
  id                    String           @id @default(cuid())
  clientId              String
  type                  ConnectionType
  status                ConnectionStatus @default(DISCONNECTED)
  marketplace           Marketplace
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  tokenExpiresAt        DateTime?
  externalAccountId     String?
  scopes                String[]
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  client                Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, type])
}

model AdAccount {
  id           String     @id @default(cuid())
  clientId     String
  profileId    String
  name         String
  currencyCode String     @default("USD")
  timezone     String     @default("America/Los_Angeles")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  client       Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaigns    Campaign[]

  @@unique([clientId, profileId])
}

model Campaign {
  id              String     @id @default(cuid())
  clientId        String
  adAccountId     String
  amazonCampaignId String
  name            String
  campaignType    String
  state           String
  budget          Decimal    @db.Decimal(12, 2)
  targetingType   String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  adAccount       AdAccount  @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  adGroups        AdGroup[]
  adMetrics       AdMetric[]

  @@unique([adAccountId, amazonCampaignId])
  @@index([clientId, state])
}

model AdGroup {
  id              String    @id @default(cuid())
  campaignId      String
  amazonAdGroupId String
  name            String
  state           String
  defaultBid      Decimal   @db.Decimal(10, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywords        Keyword[]

  @@unique([campaignId, amazonAdGroupId])
}

model Keyword {
  id              String       @id @default(cuid())
  adGroupId       String
  amazonKeywordId String
  keywordText     String
  matchType       String
  bid             Decimal      @db.Decimal(10, 2)
  state           String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  adGroup         AdGroup      @relation(fields: [adGroupId], references: [id], onDelete: Cascade)
  searchTerms     SearchTerm[]

  @@unique([adGroupId, amazonKeywordId])
  @@index([keywordText])
}

model SearchTerm {
  id             String   @id @default(cuid())
  keywordId      String?
  clientId       String
  query          String
  date           DateTime
  impressions    Int
  clicks         Int
  spend          Decimal  @db.Decimal(12, 2)
  orders         Int
  sales          Decimal  @db.Decimal(12, 2)
  acos           Decimal  @db.Decimal(8, 4)
  roas           Decimal  @db.Decimal(8, 4)
  createdAt      DateTime @default(now())
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  keyword        Keyword? @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@index([clientId, date])
  @@index([query])
}

model Product {
  id           String        @id @default(cuid())
  clientId     String
  asin         String
  sku          String?
  title        String
  imageUrl     String?
  category     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  salesMetrics SalesMetric[]
  adMetrics    AdMetric[]

  @@unique([clientId, asin])
}

model SalesMetric {
  id          String   @id @default(cuid())
  clientId    String
  productId   String?
  date        DateTime
  orderedUnits  Int
  orders      Int
  revenue     Decimal  @db.Decimal(12, 2)
  sessions    Int
  conversionRate Decimal @db.Decimal(8, 4)
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([clientId, date])
  @@index([productId, date])
}

model AdMetric {
  id          String    @id @default(cuid())
  clientId    String
  campaignId  String?
  productId   String?
  date        DateTime
  impressions Int
  clicks      Int
  spend       Decimal   @db.Decimal(12, 2)
  orders      Int
  sales       Decimal   @db.Decimal(12, 2)
  ctr         Decimal   @db.Decimal(8, 4)
  cpc         Decimal   @db.Decimal(10, 4)
  cvr         Decimal   @db.Decimal(8, 4)
  acos        Decimal   @db.Decimal(8, 4)
  roas        Decimal   @db.Decimal(8, 4)
  createdAt   DateTime  @default(now())
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([clientId, date])
  @@index([campaignId, date])
  @@index([productId, date])
}

model SQPMetric {
  id              String   @id @default(cuid())
  clientId        String
  query           String
  date            DateTime
  impressionShare Decimal  @db.Decimal(8, 4)
  clickShare      Decimal  @db.Decimal(8, 4)
  cartAddShare    Decimal  @db.Decimal(8, 4)
  purchaseShare   Decimal  @db.Decimal(8, 4)
  ppcSpend        Decimal  @db.Decimal(12, 2)
  ppcClicks       Int
  ppcOrders       Int
  ppcSales        Decimal  @db.Decimal(12, 2)
  acos            Decimal  @db.Decimal(8, 4)
  roas            Decimal  @db.Decimal(8, 4)
  createdAt       DateTime @default(now())
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
  @@index([query])
}

model AuditReport {
  id          String      @id @default(cuid())
  clientId    String
  status      AuditStatus @default(DRAFT)
  title       String
  findings    Json
  summary     String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model MarketingPlan {
  id          String   @id @default(cuid())
  clientId    String
  title       String
  plan        Json
  report      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ChatSession {
  id          String        @id @default(cuid())
  clientId    String
  title       String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages    ChatMessage[]
}

model ChatMessage {
  id          String      @id @default(cuid())
  sessionId   String
  userId      String?
  role        ChatRole
  content     String
  metadata    Json?
  createdAt   DateTime    @default(now())
  session     ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
}

model DataSyncJob {
  id          String    @id @default(cuid())
  clientId    String
  jobType     String
  status      JobStatus @default(PENDING)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  logs        Json?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, status])
}
